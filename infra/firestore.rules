rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    function isOfficer() {
      return isAuthenticated() && request.auth.token.role == 'officer';
    }
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Users Collection
    match /users/{userId} {
      // Users can read and write their own document.
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Officers can read basic user stats (e.g., for dashboards) if they share the same district.
      // (This requires a more complex check, simplified here for hackathon)
      allow read: if isOfficer();
      
      // Chat History subcollection
      match /chats/{chatId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Timeline phases (Public Read, Admin Write)
    match /timeline/{phaseId} {
      allow read: if true; // Open to public/citizens
      allow write: if isAdmin();
    }

    // Quizzes generated by system
    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only backend/admin creates quizzes
    }

    // Analytics / Leaderboards
    match /analytics/{docId} {
      allow read: if isAuthenticated(); // For global leaderboards
      allow write: if isAdmin();
    }
  }
}
