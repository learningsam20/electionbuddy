# ============================================================
# ElectionBuddy — Environment Variable Reference
# Copy this file to backend/.env and fill in your values.
# ============================================================

# ── AI Configuration ─────────────────────────────────────────
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest
# (Optional) GCP project ID if using Vertex AI
GEMINI_PROJECT_ID=your-gcp-project-id

# ── JWT Authentication ────────────────────────────────────────
# Generate a strong random value for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-random-32-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database ──────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./data/election.db
# PostgreSQL (uncomment for production):
# DATABASE_URL=postgresql://user:password@host:5432/electionbuddy

# ── App Settings ─────────────────────────────────────────────
APP_ENV=development
APP_NAME=ElectionBuddy
# Set to 1 to auto-seed demo elections and accounts on first boot
LOAD_DEMO_DATA=1
# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5731

# ── Firebase (optional — only if USE_FIREBASE=true) ──────────
USE_FIREBASE=false
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Frontend-only (put these in frontend/.env) ────────────────
# VITE_API_BASE_URL=http://localhost:8573
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
