# ElectionBuddy Environment Template
# Copy this to .env and fill in the values

# AI Configuration (Get from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
GEMINI_PROJECT_ID=your_project_id

# JWT Auth Configuration (Use a long random string in production)
SECRET_KEY=generate_a_long_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
DATABASE_URL=sqlite:///./data/election.db

# App Configuration
APP_ENV=development
CORS_ORIGINS=http://localhost:5731,http://localhost:5173
LOAD_DEMO_DATA=1

# Google Maps (Used by frontend)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
